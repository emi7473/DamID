#DamID data analysis with R Studio

#using linux ubuntu

#create new R session
conda create -n damid_analysis \
  r-base \
  bioconductor-genomicranges \
  bioconductor-iranges \
  bioconductor-rtracklayer \
  bioconductor-s4vectors \
  bioconductor-genomeinfodb \
  r-ggplot2

conda activate damid_analysis

#move into R session

#---------------------------------set-up----------------------------------
#download damidBind
if (!requireNamespace("BiocManager", quietly=TRUE))
    install.packages("BiocManager")

BiocManager::install("damidBind")

#or if newer R version, install from GitHub
install.packages("remotes")
remotes::install_github("owenjm/damidBind")

#load packages
library(damidBind)
library(GenomicRanges)
library(rtracklayer)

library(ggplot2)
library(ComplexHeatmap)
library(Gviz)
